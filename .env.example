# ── Copy this file to .env.local for local testing, and enter the same ──
# ── values in Vercel → Project → Settings → Environment Variables.     ──

# NextAuth
# Generate one with: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000 — Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Google Cloud OAuth credentials (from the Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (Claude) API key — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional override; defaults to a current Claude model if left blank
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Supabase (Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The Google Slides file ID of your default 9-slide pitch deck template
# (see TEMPLATE_TOKENS.md for how to build this). Users can override it
# per-upload by pasting their own template link.
DEFAULT_TEMPLATE_ID=

# Gemini (risk assistant chat bot on the dashboard) — https://aistudio.google.com/apikey
# Optional: leaving this blank doesn't break the rest of the app, it just
# makes the Risk Assistant button return a "not configured yet" error.
GEMINI_API_KEY=
# Optional override; defaults to Google's rolling "latest Flash" alias if left blank
GEMINI_MODEL=gemini-flash-latest

# Supabase Storage bucket name used to keep a copy of every uploaded SOW
SUPABASE_STORAGE_BUCKET=sow-uploads

# Daily task alerts (delayed / Yet-to-Start-past-Plan-Date / due-today
# emails + Chat digest) — see DASHBOARD.md's "Daily Task Alerts" section.
#
# Encrypts the one long-lived Google refresh token this app stores
# server-side (supabase/schema.sql's user_google_tokens table), so the
# unattended daily check can read tracker sheets and send email with
# nobody's browser open. Must be a 32-byte key, base64-encoded.
# Generate one with: openssl rand -base64 32
# Never reuse NEXTAUTH_SECRET or any other existing secret for this.
TOKEN_ENCRYPTION_KEY=

# Shared secret Vercel Cron sends back as "Authorization: Bearer
# <CRON_SECRET>" on every scheduled call to /api/cron/daily-alerts — without
# this, anyone who found that URL could trigger the alert run themselves.
# Generate one the same way: openssl rand -base64 32
CRON_SECRET=
