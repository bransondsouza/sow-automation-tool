# ── Copy this file to .env.local for local testing, and enter the same ──
# ── values in Vercel → Project → Settings → Environment Variables.     ──

# NextAuth
# Generate one with: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000 — Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Google Cloud OAuth credentials (from the Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (Claude) API key — https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional override; defaults to a current Claude model if left blank
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Supabase (Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# The Google Slides file ID of your default 9-slide pitch deck template
# (see TEMPLATE_TOKENS.md for how to build this). Users can override it
# per-upload by pasting their own template link.
DEFAULT_TEMPLATE_ID=

# Supabase Storage bucket name used to keep a copy of every uploaded SOW
SUPABASE_STORAGE_BUCKET=sow-uploads
